#!/usr/bin/env node
import enquirer from "enquirer";
import Quiz from "../lib/quiz.js";

const { Select, Toggle } = enquirer;

async function main() {
  title();
  const level = await chooseLevel();
  const japaneseHint = await isJapaneseHint();
  const options = { level, japaneseHint };
  const quiz = new Quiz(options);
  await quiz.run();
}

function title() {
  const title = [
    "🦉 🐈 What Are We Called? 🐬 🐑",
    "~Animal Collective Noun quiz~",
    "",
  ];
  console.log(title.join("\n"));
}

function chooseLevel() {
  const prompt = new Select({
    name: "level",
    message: "Select a level",
    choices: ["easy", "normal", "difficult"],
  });

  return prompt.run();
}

function isJapaneseHint() {
  const prompt = new Toggle({
    message: "Show a Japanese animal name hint?",
    enabled: "Yes",
    disabled: "No",
  });

  return prompt.run();
}

main();
